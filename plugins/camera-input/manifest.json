{
  "name": "Camera (polka-dot)",
  "author": "vj-app",
  "version": "0.1.0",
  "outputType": "canvas",
  "entry": "index.js",
  "params": [
    { "key": "cameraDeviceId", "type": "camera", "default": ""                                       },
    { "key": "gridSize",       "type": "int",    "default": 24,  "min": 4,   "max": 96, "step": 1   },
    { "key": "dotSize",        "type": "float",  "default": 0.8, "min": 0.1, "max": 1,  "step": 0.05 },
    { "key": "mirror",         "type": "bool",   "default": true                                     }
  ]
}
