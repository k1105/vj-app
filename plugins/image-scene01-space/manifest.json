{
  "name": "scene01-space",
  "author": "user",
  "version": "0.1.0",
  "outputType": "canvas",
  "category": "image",
  "entry": "../../templates/image-asset/index.js",
  "params": [
    {
      "key": "images",
      "type": "strings",
      "default": [
        "vj-asset://local/plugins/image-scene01-space/img0.png"
      ]
    },
    {
      "key": "idx",
      "type": "int",
      "default": 0,
      "min": 0,
      "max": 0,
      "step": 1
    },
    {
      "key": "grid",
      "type": "int",
      "default": 4,
      "min": 1,
      "max": 16,
      "step": 1
    },
    {
      "key": "scale",
      "type": "float",
      "default": 1,
      "min": 0.1,
      "max": 3,
      "step": 0.05
    },
    {
      "key": "vibrate",
      "type": "bool",
      "default": true
    },
    {
      "key": "bgColor",
      "type": "color",
      "default": "#000000"
    },
    {
      "key": "bgOpacity",
      "type": "float",
      "default": 0,
      "min": 0,
      "max": 1,
      "step": 0.01
    }
  ]
}
